
{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information with role-based access",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "photoURL": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "staff", "customer"],
          "description": "The user's privilege level"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review submitted by a user",
      "type": "object",
      "properties": {
        "productId": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "userName": {
          "type": "string"
        },
        "userLocation": {
          "type": "string"
        },
        "rating": {
          "type": "number"
        },
        "title": {
          "type": "string"
        },
        "comment": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "published"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["productId", "rating", "comment", "status"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Store user profile data and roles"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Store product reviews"
    }
  }
}
